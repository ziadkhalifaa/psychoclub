# PsychoClub Platform Environment Variables Template
# Copy this file to .env and fill in the values

# Server Configuration
PORT=3000

# Security
# CRITICAL: Change this to a long random string in production
JWT_SECRET=your_jwt_secret_here

# Database
# PostgreSQL Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/psychoclub?schema=public"

# AI Integration
GEMINI_API_KEY="your_gemini_api_key_here"

# App Metadata
APP_URL="http://localhost:3000"
